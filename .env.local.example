# Google Maps Platform API key
# Get one at: https://console.cloud.google.com/
# Enable: "Map Tiles API" for Photorealistic 3D Tiles
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Cesium Ion token (optional — only needed for Cesium Ion assets)
# Get one free at: https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here
